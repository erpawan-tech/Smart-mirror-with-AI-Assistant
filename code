import speech_recognition as sr
import pyttsx3
from groq import Groq
import os

# Groq API Client
client = Groq(
    api_key=os.getenv("GROQ_API_KEY")
)

# Speech Recognition
recognizer = sr.Recognizer()
recognizer.energy_threshold = 300
recognizer.pause_threshold = 0.8

# Text To Speech
engine = pyttsx3.init()

# Conversation Memory
messages = [
    {
        "role": "system",
        "content": "Give short answers in 1-2 lines only."
    }
]


def speak(text):
    print("AI:", text)

    engine.say(text)
    engine.runAndWait()


def listen():
    with sr.Microphone() as source:
        try:
            print("Listening...")

            recognizer.adjust_for_ambient_noise(source)

            audio = recognizer.listen(
                source,
                timeout=5,
                phrase_time_limit=10
            )

            text = recognizer.recognize_google(audio)

            print("You:", text)

            return text.lower()

        except Exception as e:
            print("Speech Error:", e)
            return ""


print("=" * 50)
print(" Smart AI Magic Mirror Assistant Started ")
print(" Say 'exit' to quit ")
print("=" * 50)

while True:

    query = listen()

    if not query:
        continue

    if "exit" in query:
        speak("Goodbye")
        break

    messages.append(
        {
            "role": "user",
            "content": query
        }
    )

    try:

        response = client.chat.completions.create(
            model="llama3-70b-8192",
            messages=messages
        )

        reply = response.choices[0].message.content

        print("\nAI:", reply)

        speak(reply)

        messages.append(
            {
                "role": "assistant",
                "content": reply
            }
        )

        # Limit chat history
        if len(messages) > 6:
            messages.pop(1)

    except Exception as e:
        print("API Error:", e)
